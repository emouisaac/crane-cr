NODE_ENV=development
PORT=3000
APP_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crane_credit
DATABASE_SSL=false
JWT_ACCESS_SECRET=replace-with-long-random-value
JWT_REFRESH_SECRET=replace-with-long-random-value
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
COOKIE_DOMAIN=
COOKIE_SECURE=false
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=replace-with-strong-password
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_NAME=Crane Super Admin
STORAGE_ROOT=backend/storage
UPLOAD_ROOT=backend/storage/uploads
BACKUP_ROOT=backend/storage/backups
CSRF_COOKIE_NAME=crane_csrf
AUTO_BACKUP_CRON=0 2 * * *
MAX_FAILED_LOGIN_WINDOW_MINUTES=15
MAX_FAILED_LOGIN_ATTEMPTS=7
